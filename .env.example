# Araripe Deforestation Monitor — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── NASA Earthdata (optional, only for HLS as an extra source) ──────────────
# Needed only when running with --extra-sources hls; the default S2 pipeline
# does not require these.
EARTHDATA_USERNAME=
EARTHDATA_PASSWORD=

# ─── Cloudflare R2 (for COG storage, needed for upload script) ───────────────
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY=
R2_SECRET_KEY=

# ─── Planetary Computer (optional, increases rate limits) ────────────────────
PC_SDK_SUBSCRIPTION_KEY=
